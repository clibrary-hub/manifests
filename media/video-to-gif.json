{
  "name": "video-to-gif",
  "version": "1.0.0",
  "category": "media",
  "description": "Convert a video clip to an optimized GIF with configurable FPS, resolution, and loop count.",
  "intent_triggers": [
    "影片轉 GIF",
    "把 mp4 變成 GIF",
    "把這個影片轉成動圖",
    "convert video to GIF",
    "make a GIF from video",
    "video to GIF",
    "生成 GIF",
    "錄影轉 GIF",
    "create animated GIF from video",
    "mp4 to gif",
    "把影片做成表情包",
    "截取影片片段轉 GIF",
    "turn clip into GIF",
    "export video as GIF",
    "動畫 GIF 製作"
  ],
  "input_schema": {
    "input": {
      "type": "string",
      "required": true,
      "description": "Path to input video file (mp4, mov, avi, webm, mkv)"
    },
    "output": {
      "type": "string",
      "required": false,
      "description": "Output GIF path; defaults to <input_name>.gif"
    },
    "start": {
      "type": "string",
      "required": false,
      "description": "Start time (e.g. 00:00:05 or 5)"
    },
    "duration": {
      "type": "number",
      "required": false,
      "description": "Duration in seconds to capture"
    },
    "fps": {
      "type": "integer",
      "required": false,
      "default": 15,
      "description": "Frames per second (1–30)"
    },
    "width": {
      "type": "integer",
      "required": false,
      "description": "Output width in pixels; height is auto-scaled"
    },
    "loop": {
      "type": "integer",
      "required": false,
      "default": 0,
      "description": "Loop count: 0 = infinite, 1 = play once"
    }
  },
  "output_schema": {
    "format": "json",
    "fields": ["output_path", "file_size_bytes", "width", "height", "fps", "duration_seconds", "frame_count"]
  },
  "examples": [
    {
      "intent": "把這個 mp4 的前 5 秒轉成 GIF",
      "invocation": "video-to-gif --input clip.mp4 --duration 5 --fps 15 --width 480"
    },
    {
      "intent": "convert a specific section of a video to GIF",
      "invocation": "video-to-gif --input demo.mp4 --start 00:00:10 --duration 8 --output demo.gif"
    },
    {
      "intent": "高品質 GIF 輸出",
      "invocation": "video-to-gif --input interview.mov --fps 24 --width 640 --output highlight.gif"
    }
  ],
  "error_codes": {
    "E001": "Input file not found",
    "E002": "Unsupported video format",
    "E003": "ffmpeg not installed — run: brew install ffmpeg",
    "E004": "Start time exceeds video duration",
    "E005": "Output file size exceeds 50MB — reduce fps or width"
  },
  "tags": ["gif", "video", "convert", "animation", "media", "ffmpeg", "mp4"]
}
