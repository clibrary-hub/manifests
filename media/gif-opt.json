  "input_schema": {
    "path": {
      "type": "string",
      "required": true,
      "description": "Target project directory path"
    },
    "depth": {
      "type": "integer",
      "required": false,
      "description": "Maximum directory depth to scan"
    },
    "ext": {
      "type": "string",
      "required": false,
      "description": "Filter by file extension (e.g., py)"
    },
    "exclude": {
      "type": "array",
      "required": false,
      "description": "Directory names to exclude"
    },
    "output": {
      "type": "enum",
      "required": false,
      "default": "terminal",
      "description": "Output format: terminal, markdown, or json"
    },
    "respect_gitignore": {
      "type": "boolean",
      "required": false,
      "default": false,
      "description": "Respect .gitignore rules"
    },
    "annotate": {
      "type": "boolean",
      "required": false,
      "default": false,
      "description": "Infer and annotate file purposes"
    },
    "stats": {
      "type": "boolean",
      "required": false,
      "default": false,
      "description": "Show language distribution statistics"
    }
  },
  "output_schema": {
    "format": "text",
    "fields": [
      "tree",
      "language_stats",
      "entry_points",
      "file_count",
      "total_size"
    ]
  },
  "examples": [
    {
