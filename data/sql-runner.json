{
  "name": "sql-runner",
  "version": "1.0.0",
  "category": "data",
  "description": "Execute SQL queries against a database and return results as JSON or CSV.",
  "intent_triggers": [
    "跑 SQL 查詢",
    "查資料庫",
    "執行 SQL",
    "幫我查一下資料庫",
    "我要撈資料",
    "run a SQL query",
    "query the database",
    "execute SQL against the DB",
    "select data from database",
    "幫我查上週的銷售總額",
    "列出所有用戶資料",
    "從資料庫取得報表",
    "SQL select statement",
    "撈出符合條件的資料",
    "get records from database"
  ],
  "input_schema": {
    "query": {
      "type": "string",
      "required": true,
      "description": "SQL query to execute (SELECT only for safety)"
    },
    "connection_string": {
      "type": "string",
      "required": false,
      "description": "Database connection string; falls back to DB_URL env var"
    },
    "output_format": {
      "type": "enum",
      "required": false,
      "default": "json",
      "description": "Output format: json or csv"
    },
    "limit": {
      "type": "integer",
      "required": false,
      "default": 100,
      "description": "Maximum number of rows to return"
    }
  },
  "output_schema": {
    "format": "json",
    "fields": [
      "rows",
      "row_count",
      "columns",
      "execution_time_ms"
    ]
  },
  "examples": [
    {
      "intent": "查上週的銷售總額",
      "invocation": "sql-runner --query \"SELECT SUM(amount) as total FROM orders WHERE created_at >= NOW() - INTERVAL '7 days'\""
    },
    {
      "intent": "list all active users",
      "invocation": "sql-runner --query \"SELECT id, email, created_at FROM users WHERE active = true\" --limit 50"
    },
    {
      "intent": "匯出 CSV 格式",
      "invocation": "sql-runner --query \"SELECT * FROM products\" --output-format csv"
    }
  ],
  "error_codes": {
    "E001": "Connection failed — check DB_URL or --connection-string",
    "E002": "Query syntax error",
    "E003": "Only SELECT queries are allowed",
    "E004": "Query timeout (>30s)"
  },
  "tags": [
    "sql",
    "database",
    "query",
    "postgresql",
    "mysql",
    "sqlite"
  ],
  "status": "spec"
}