{
  "name": "sysprompt-git",
  "version": "1.0.0",
  "category": "devops",
  "description": "Version control for system prompts with change tracking, effect scoring, and A/B testing support.",
  "intent_triggers": [
    "幫我管理 System Prompt 的版本",
    "比較兩個版本的 Prompt 差異",
    "回滾到之前的 System Prompt",
    "記錄這次修改的效果評分",
    "幫我做 Prompt 的 A/B 測試",
    "version control my system prompt",
    "compare two versions of a prompt",
    "checkout an older prompt version",
    "rate the effectiveness of a prompt version",
    "匯出兩個 Prompt 版本做並行測試"
  ],
  "input_schema": {
    "command": {
      "type": "enum",
      "required": true,
      "description": "Subcommand: commit, log, diff, checkout, list, rate, ranking, ab-export, ab-record",
      "default": "list"
    },
    "file": {
      "type": "string",
      "required": false,
      "description": "System prompt file path"
    },
    "message": {
      "type": "string",
      "required": false,
      "description": "Commit message (commit command)"
    },
    "version": {
      "type": "string",
      "required": false,
      "description": "Version identifier for checkout/rate/diff"
    },
    "score": {
      "type": "integer",
      "required": false,
      "description": "Effectiveness score 1-10 (rate command)"
    },
    "note": {
      "type": "string",
      "required": false,
      "description": "Note about the version or A/B result"
    },
    "output": {
      "type": "string",
      "required": false,
      "description": "Output directory for A/B export"
    }
  },
  "output_schema": {
    "format": "text",
    "fields": ["version", "timestamp", "score", "message", "diff"]
  },
  "examples": [
    {
      "intent": "儲存當前 System Prompt 版本",
      "invocation": "sysprompt-git commit system_prompt.md -m \"加入繁體中文規則\""
    },
    {
      "intent": "比較兩個版本的差異",
      "invocation": "sysprompt-git diff system_prompt.md v3 v5"
    }
  ],
  "error_codes": {
    "1": "Prompt file not found",
    "2": "Version does not exist"
  },
  "tags": ["prompt", "version-control", "git-like", "ab-test"]
}
