{
  "name": "recent-changes",
  "version": "1.0.0",
  "category": "devops",
  "description": "Detect recently modified files in a project with diff summaries, Git blame info, and unstaged change detection.",
  "intent_triggers": [
    "最近有哪些檔案被改過",
    "幫我看一下這個專案最近的變更",
    "列出今天修改過的程式碼",
    "我想知道這個檔案是誰改的、改了什麼",
    "顯示未 commit 的修改內容",
    "show me recent changes in this repo",
    "what files were modified lately",
    "list changes since yesterday",
    "give me a diff summary of recent edits",
    "幫我產出一份最近變更的 Markdown 報告"
  ],
  "input_schema": {
    "path": {
      "type": "string",
      "required": true,
      "description": "Target repository or directory path"
    },
    "since": {
      "type": "string",
      "required": false,
      "default": "24 hours ago",
      "description": "Time range expression (e.g., '3 hours ago', '2026-04-24')"
    },
    "limit": {
      "type": "integer",
      "required": false,
      "description": "Maximum number of results to display"
    },
    "code_only": {
      "type": "boolean",
      "required": false,
      "default": false,
      "description": "Show only code files"
    },
    "sort": {
      "type": "enum",
      "required": false,
      "description": "Sort order: changes (by change volume) or time"
    },
    "exclude": {
      "type": "array",
      "required": false,
      "description": "Patterns to exclude (e.g., '*.lock', 'dist/')"
    },
    "detail": {
      "type": "boolean",
      "required": false,
      "default": false,
      "description": "Show per-file diff summary"
    },
    "blame": {
      "type": "boolean",
      "required": false,
      "default": false,
      "description": "Show Git blame information"
    },
    "output": {
      "type": "string",
      "required": false,
      "description": "Output file path (Markdown)"
    }
  },
  "output_schema": {
    "format": "text",
    "fields": ["file_path", "status", "plus_minus", "time", "summary", "author"]
  },
  "examples": [
    {
      "intent": "列出最近 3 小時內的變更",
      "invocation": "recent-changes . --since \"3 hours ago\" --detail"
    },
    {
      "intent": "Export recent changes to Markdown",
      "invocation": "recent-changes . --since \"2026-04-24\" --code-only -o changes.md"
    }
  ],
  "error_codes": {
    "1": "Target path is not a Git repository or directory",
    "2": "Invalid time expression"
  },
  "tags": ["git", "diff", "changes", "blame", "devops"]
}
