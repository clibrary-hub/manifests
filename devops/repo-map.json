{
  "name": "repo-map",
  "version": "1.0.0",
  "category": "devops",
  "description": "Scan a project directory and produce a concise structure summary with file sizes, language distribution, and key entry points.",
  "intent_triggers": [
    "幫我畫出這個專案的目錄結構",
    "這個 repo 裡面有哪些程式語言",
    "顯示專案的入口點和設定檔",
    "幫我產生一份精簡的專案地圖",
    "這個專案有多大、檔案怎麼分佈",
    "show me the structure of this repo",
    "generate a project map",
    "what languages are used in this project",
    "list key entry points and config files",
    "幫我 scan 一下這個資料夾的檔案結構和大小"
  ],
  "input_schema": {
    "path": {
      "type": "string",
      "required": true,
      "description": "Target project directory path"
    },
    "depth": {
      "type": "integer",
      "required": false,
      "description": "Maximum directory depth to scan"
    },
    "ext": {
      "type": "string",
      "required": false,
      "description": "Filter by file extension (e.g., py)"
    },
    "exclude": {
      "type": "array",
      "required": false,
      "description": "Directory names to exclude"
    },
    "output": {
      "type": "enum",
      "required": false,
      "default": "terminal",
      "description": "Output format: terminal, markdown, or json"
    },
    "respect_gitignore": {
      "type": "boolean",
      "required": false,
      "default": false,
      "description": "Respect .gitignore rules"
    },
    "annotate": {
      "type": "boolean",
      "required": false,
      "default": false,
      "description": "Infer and annotate file purposes"
    },
    "stats": {
      "type": "boolean",
      "required": false,
      "default": false,
      "description": "Show language distribution statistics"
    }
  },
  "output_schema": {
    "format": "text",
    "fields": ["tree", "language_stats", "entry_points", "file_count", "total_size"]
  },
  "examples": [
    {
      "intent": "掃描當前專案並顯示語言統計",
      "invocation": "repo-map . --stats --depth 3"
    },
    {
      "intent": "Export project map to Markdown",
      "invocation": "repo-map /path/to/project --respect-gitignore -o markdown > project_map.md"
    }
  ],
  "error_codes": {
    "1": "Target directory not found",
    "2": "Permission denied accessing directory"
  },
  "tags": ["repo", "structure", "tree", "language-stats", "devops"]
}
