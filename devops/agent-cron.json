{
  "name": "agent-cron",
  "version": "1.0.0",
  "category": "devops",
  "description": "Schedule and manage cron-like recurring agent tasks with history tracking.",
  "intent_triggers": [
    "幫我設定定時任務",
    "每天早上九點跑報告要怎麼排",
    "查看所有排程的執行狀態",
    "暫停這個週報任務",
    "手動觸發一次排程",
    "schedule a daily job",
    "list all cron jobs",
    "pause the health check task",
    "how do I run a recurring task every hour",
    "幫我啟動 cron scheduler 背景執行"
  ],
  "input_schema": {
    "action": {
      "type": "enum",
      "required": true,
      "description": "Action: add, list, pause, resume, remove, trigger, history, last-output, start, stop",
      "default": null
    },
    "name": {
      "type": "string",
      "required": false,
      "description": "Task name",
      "default": null
    },
    "cron": {
      "type": "string",
      "required": false,
      "description": "Cron expression for scheduling",
      "default": null
    },
    "cmd": {
      "type": "string",
      "required": false,
      "description": "Command to execute",
      "default": null
    },
    "daemon": {
      "type": "boolean",
      "required": false,
      "description": "Run scheduler in background daemon mode",
      "default": false
    }
  },
  "output_schema": {
    "format": "text",
    "fields": [
      "task_name",
      "cron_expression",
      "status",
      "next_run",
      "history"
    ]
  },
  "examples": [
    {
      "intent": "每天早上 9 點執行每日報告",
      "invocation": "agent-cron add \"每日報告\" --cron \"0 9 * * *\" --cmd \"uv run daily_report.py\""
    },
    {
      "intent": "列出所有排程任務",
      "invocation": "agent-cron list"
    },
    {
      "intent": "Start scheduler in background",
      "invocation": "agent-cron start --daemon"
    }
  ],
  "error_codes": {
    "1": "Invalid cron expression",
    "2": "Task not found"
  },
  "tags": [
    "cron",
    "scheduler",
    "automation",
    "task",
    "devops"
  ],
  "status": "available",
  "source": "https://github.com/clibrary-hub/cli-tools/tree/main/manifests/D63-agent-cron"
}