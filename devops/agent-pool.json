{
  "name": "agent-pool",
  "version": "1.0.0",
  "category": "devops",
  "description": "Manage a prioritized task queue with concurrency control, dependency chains, and monitoring.",
  "intent_triggers": [
    "提交一個新任務到佇列",
    "設定任務池的並行上限",
    "查看目前任務執行狀態",
    "啟動三個 worker 來消費任務",
    "取消這個程式碼審查任務",
    "submit a task to the queue",
    "show me the agent pool status",
    "start workers to process the queue",
    "set max parallel jobs to 3",
    "幫我監控任務池的即時狀態"
  ],
  "input_schema": {
    "action": {
      "type": "enum",
      "required": true,
      "description": "Action: submit, status, config, pause, resume, cancel, worker, monitor, history, output",
      "default": null
    },
    "name": {
      "type": "string",
      "required": false,
      "description": "Task name",
      "default": null
    },
    "cmd": {
      "type": "string",
      "required": false,
      "description": "Command to execute",
      "default": null
    },
    "priority": {
      "type": "enum",
      "required": false,
      "description": "Task priority: low, normal, high",
      "default": "normal"
    },
    "after": {
      "type": "string",
      "required": false,
      "description": "Dependency task name to wait for",
      "default": null
    },
    "max_parallel": {
      "type": "integer",
      "required": false,
      "description": "Maximum concurrent tasks",
      "default": null
    },
    "count": {
      "type": "integer",
      "required": false,
      "description": "Number of workers to start",
      "default": 1
    },
    "last": {
      "type": "integer",
      "required": false,
      "description": "Number of history entries to show",
      "default": 20
    }
  },
  "output_schema": {
    "format": "text",
    "fields": ["task_id", "task_name", "priority", "status", "active_count", "queued_count"]
  },
  "examples": [
    {
      "intent": "提交一個高優先級的緊急修復任務",
      "invocation": "agent-pool submit \"緊急修復\" --cmd \"uv run hotfix.py\" --priority high"
    },
    {
      "intent": "啟動三個 worker 處理佇列",
      "invocation": "agent-pool worker start --count 3"
    },
    {
      "intent": "Open the real-time monitor dashboard",
      "invocation": "agent-pool monitor"
    }
  ],
  "error_codes": {
    "1": "Task dependency not found",
    "2": "Worker process failed to start"
  },
  "tags": ["queue", "task-pool", "worker", "concurrency", "devops"]
}
