{
  "name": "docker-cleanup",
  "version": "1.0.0",
  "category": "devops",
  "description": "Remove stopped containers, dangling images, unused volumes, and build cache to reclaim Docker disk space.",
  "intent_triggers": [
    "зҡңпҶұ? Docker",
    "?иҠЈ?зҳқоҳҠоң…??Docker ж‘°еӯөоЁ–",
    "Docker иқӨојҪ?иқӣзІ№?йҠқпҡ—?",
    "docker cleanup",
    "remove unused docker resources",
    "clean up docker images and containers",
    "prune docker",
    "?п•һоңӣ Docker иқӨојҪ?",
    "?иҠЈ??п“Ӯ? Docker image",
    "docker disk space full",
    "зҡңпҶіоЁ’ docker build cache",
    "remove dangling images",
    "Docker ?пҒөо°ғзҡңпҶұ?",
    "free up docker storage",
    "docker system prune"
  ],
  "input_schema": {
    "target": {
      "type": "enum",
      "required": false,
      "default": "all",
      "description": "What to clean: all, containers, images, volumes, cache"
    },
    "force": {
      "type": "boolean",
      "required": false,
      "default": false,
      "description": "Skip confirmation prompt"
    },
    "dry_run": {
      "type": "boolean",
      "required": false,
      "default": false,
      "description": "Show what would be removed without actually removing"
    },
    "older_than": {
      "type": "string",
      "required": false,
      "description": "Only remove resources older than this duration (e.g. 24h, 7d)"
    }
  },
  "output_schema": {
    "format": "json",
    "fields": [
      "removed_containers",
      "removed_images",
      "removed_volumes",
      "reclaimed_bytes"
    ]
  },
  "examples": [
    {
      "intent": "зҡңпҶұ??ВҖ?пҗӨ??еҮҪ? Docker йһҲпӢӘ?",
      "invocation": "docker-cleanup --target all --force"
    },
    {
      "intent": "dry run to see what would be deleted",
      "invocation": "docker-cleanup --dry-run"
    },
    {
      "intent": "?иҠёпҚӢ??7 жҶӯжӢҷ???image",
      "invocation": "docker-cleanup --target images --older-than 7d --force"
    }
  ],
  "error_codes": {
    "E001": "Docker daemon not running",
    "E002": "Insufficient permissions ??try running with sudo",
    "E003": "Cannot remove image in use by running container"
  },
  "tags": [
    "docker",
    "cleanup",
    "devops",
    "containers",
    "images",
    "disk-space",
    "maintenance"
  ],
  "status": "available",
  "source": "https://github.com/clibrary-hub/cli-tools/tree/main/manifests/Q321-docker-cleanup"
}