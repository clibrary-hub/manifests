{
  "name": "checkpoint",
  "version": "1.0.0",
  "category": "devops",
  "description": "Track agent task progress with resumable checkpoints so interrupted jobs can continue from the last save point.",
  "intent_triggers": [
    "建立一個可追蹤的任務",
    "標記這個批次轉檔的進度",
    "查看目前任務完成了多少",
    "幫我恢復上次中斷的任務",
    "設定斷點讓任務可以從中間繼續",
    "create a checkpoint for the long task",
    "mark item 42 as done in the batch job",
    "show me the progress of the image compression task",
    "resume processing from the last checkpoint",
    "list remaining items to process",
    "追蹤任務的執行進度",
    "checkpoint這個任務的狀態"
  ],
  "input_schema": {
    "task": {
      "type": "string",
      "required": true,
      "description": "Task name or identifier"
    },
    "total": {
      "type": "integer",
      "required": false,
      "description": "Total number of items for the task"
    },
    "from_list": {
      "type": "string",
      "required": false,
      "description": "Path to a file containing the item list"
    },
    "item": {
      "type": "integer",
      "required": false,
      "description": "Item index to mark as done or failed"
    },
    "range": {
      "type": "string",
      "required": false,
      "description": "Range of items to mark (e.g., 1-50)"
    },
    "reason": {
      "type": "string",
      "required": false,
      "description": "Reason for marking an item as failed"
    },
    "force": {
      "type": "boolean",
      "required": false,
      "default": false,
      "description": "Force removal without confirmation"
    }
  },
  "output_schema": {
    "format": "text",
    "fields": [
      "total",
      "completed",
      "failed",
      "pending",
      "progress_percent",
      "estimated_remaining"
    ]
  },
  "examples": [
    {
      "intent": "建立一個處理 1000 個檔案的任務",
      "invocation": "checkpoint create \"批次轉檔\" --total 1000"
    },
    {
      "intent": "標記第 42 項已完成",
      "invocation": "checkpoint done \"批次轉檔\" --item 42"
    },
    {
      "intent": "查看目前任務進度",
      "invocation": "checkpoint status \"批次轉檔\""
    }
  ],
  "error_codes": {
    "1": "Task not found",
    "2": "Item already marked done"
  },
  "tags": [
    "checkpoint",
    "task",
    "resume",
    "progress",
    "devops"
  ],
  "status": "available",
  "source": "https://github.com/clibrary-hub/cli-tools/tree/main/manifests/D65-checkpoint"
}