{
  "name": "env-sync",
  "version": "1.0.0",
  "category": "devops",
  "description": "Manage and synchronize environment variables across multiple environments, detect missing keys, and validate formats.",
  "intent_triggers": [
    "比對兩個 .env 檔的差異",
    "同步 staging 和 production 的環境變數",
    "找出 .env 裡缺少的 key",
    "驗證環境變數格式是否正確",
    "掃描程式碼裡用到的環境變數",
    "compare two .env files",
    "sync missing env keys from template",
    "find missing environment variables",
    "validate my .env configuration",
    "幫我檢查 .env 跟 .env.example 有沒有對齊"
  ],
  "input_schema": {
    "command": {
      "type": "enum",
      "required": true,
      "description": "Sub-command: diff, missing, validate, audit, sync, matrix, scan, template",
      "default": "diff"
    },
    "env": {
      "type": "string",
      "required": true,
      "description": "Primary .env file path"
    },
    "target": {
      "type": "string",
      "required": false,
      "description": "Secondary .env file for comparison"
    },
    "template": {
      "type": "string",
      "required": false,
      "description": "Template .env file to compare against"
    },
    "from": {
      "type": "string",
      "required": false,
      "description": "Source .env to sync keys from"
    },
    "check_format": {
      "type": "boolean",
      "required": false,
      "default": false,
      "description": "Validate value formats (URL, email, key)"
    },
    "output": {
      "type": "string",
      "required": false,
      "description": "Output file path for matrix report"
    }
  },
  "output_schema": {
    "format": "text",
    "fields": ["comparison_matrix", "missing_keys", "format_errors", "sensitive_vars"]
  },
  "examples": [
    {
      "intent": "比對兩個環境變數檔案的差異",
      "invocation": "env-sync diff .env .env.production"
    },
    {
      "intent": "從模板同步缺少的 key",
      "invocation": "env-sync sync .env --from .env.example"
    },
    {
      "intent": "掃描程式碼生成 .env.example",
      "invocation": "env-sync scan src/ -o .env.example"
    }
  ],
  "error_codes": {
    "1": "Env file not found",
    "2": "Invalid env format",
    "3": "Sensitive value detected in audit"
  },
  "tags": ["environment", "devops", "sync", "validation", "security", "dotenv"]
}
