{
  "name": "ppt-designer",
  "version": "1.0.0",
  "category": "productivity",
  "description": "Generate well-designed PowerPoint presentations from markdown or JSON input files.",
  "intent_triggers": [
    "從 Markdown 產生 PPT",
    "幫我做一份簡報",
    "生成設計感的簡報檔案",
    "把報告內容轉成投影片",
    "產生 demo 簡報範例",
    "generate a PowerPoint from markdown",
    "create a designed presentation",
    "build slides from a report file",
    "produce a dark-themed PPT",
    "用 JSON 資料自動生成 pptx"
  ],
  "input_schema": {
    "input": {
      "type": "string",
      "required": false,
      "description": "Input file path (md or json)"
    },
    "output": {
      "type": "string",
      "required": false,
      "default": "report.pptx",
      "description": "Output PowerPoint file path"
    },
    "theme": {
      "type": "enum",
      "required": false,
      "default": "dark",
      "description": "Presentation theme: dark or light"
    },
    "demo": {
      "type": "boolean",
      "required": false,
      "default": false,
      "description": "Generate a demo report (CLI tools overview)"
    },
    "list_themes": {
      "type": "boolean",
      "required": false,
      "default": false,
      "description": "List available themes"
    }
  },
  "output_schema": {
    "format": "text",
    "fields": ["output_file", "slide_count"]
  },
  "examples": [
    {
      "intent": "從 Markdown 檔案生成深色主題簡報",
      "invocation": "ppt-designer input.md -o report.pptx --theme dark"
    },
    {
      "intent": "產生示範簡報",
      "invocation": "ppt-designer --demo -o demo_report.pptx"
    }
  ],
  "error_codes": {
    "1": "Input file not found",
    "2": "python-pptx dependency missing"
  },
  "tags": ["ppt", "presentation", "powerpoint", "markdown"]
}
