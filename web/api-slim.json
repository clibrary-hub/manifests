{
  "name": "api-slim",
  "version": "1.0.0",
  "category": "web",
  "description": "Intelligently trim large API responses to fit context limits while preserving structure and schema.",
  "intent_triggers": [
    "把這個 API 回應裁減到 2000 tokens",
    "從 URL 抓取並瘦身 JSON",
    "只保留第一筆資料當範例",
    "分析這個 API 回應的結構",
    "推導這份資料的 JSON Schema",
    "slim down this API response",
    "fetch and trim JSON from a URL",
    "keep only the first item as example",
    "analyze the structure of this response",
    "幫我把這個 50K tokens 的回應壓到 500"
  ],
  "input_schema": {
    "action": {
      "type": "enum",
      "required": true,
      "description": "Action: slim, fetch, analyze, schema",
      "default": null
    },
    "input": {
      "type": "string",
      "required": false,
      "description": "Input file path, URL, or '-' for stdin",
      "default": null
    },
    "output": {
      "type": "string",
      "required": false,
      "description": "Output file path",
      "default": null
    },
    "max_tokens": {
      "type": "integer",
      "required": false,
      "description": "Maximum tokens for slimmed output",
      "default": null
    },
    "strategy": {
      "type": "enum",
      "required": false,
      "description": "Slimming strategy: first or schema",
      "default": null
    },
    "fields": {
      "type": "string",
      "required": false,
      "description": "Comma-separated fields to保留",
      "default": null
    },
    "flatten": {
      "type": "boolean",
      "required": false,
      "description": "Flatten nested objects",
      "default": false
    }
  },
  "output_schema": {
    "format": "json",
    "fields": ["slimmed_data", "original_tokens", "reduced_tokens", "schema"]
  },
  "examples": [
    {
      "intent": "從檔案裁剪 API 回應",
      "invocation": "api-slim slim response.json --max-tokens 2000"
    },
    {
      "intent": "從 URL 抓取並裁剪",
      "invocation": "api-slim fetch https://api.example.com/users -o slimmed.json"
    },
    {
      "intent": "Analyze API response structure",
      "invocation": "api-slim analyze response.json"
    }
  ],
  "error_codes": {
    "1": "Invalid JSON input",
    "2": "URL fetch failed"
  },
  "tags": ["api", "json", "trim", "token-limit", "web"]
}
