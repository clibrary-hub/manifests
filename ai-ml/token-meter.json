{
  "name": "token-meter",
  "version": "1.0.0",
  "category": "ai-ml",
  "description": "Track token usage and API costs across AI platforms, calculate fees, and set budget alerts.",
  "intent_triggers": [
    "計算這段文字的 Token 數",
    "幫我追蹤 API 費用",
    "這個月用了多少 Token",
    "設定預算提醒",
    "計算這個目錄所有檔案的 Token",
    "count tokens in this text",
    "track my LLM API spending",
    "how many tokens did I use this month",
    "set a monthly budget alert",
    "幫我算一下這份文件的 token 數量"
  ],
  "input_schema": {
    "command": {
      "type": "enum",
      "required": true,
      "description": "Subcommand: count, log, import, report, budget",
      "default": "count"
    },
    "file": {
      "type": "string",
      "required": false,
      "description": "File path to count tokens"
    },
    "directory": {
      "type": "string",
      "required": false,
      "description": "Directory path for batch token counting"
    },
    "model": {
      "type": "string",
      "required": false,
      "default": "gpt-4o",
      "description": "Model name for tokenizer"
    },
    "recursive": {
      "type": "boolean",
      "required": false,
      "default": false,
      "description": "Recursively count tokens in directory"
    },
    "input_tokens": {
      "type": "integer",
      "required": false,
      "description": "Input token count (log command)"
    },
    "output_tokens": {
      "type": "integer",
      "required": false,
      "description": "Output token count (log command)"
    },
    "month": {
      "type": "string",
      "required": false,
      "description": "Month for report in YYYY-MM format"
    },
    "group_by": {
      "type": "enum",
      "required": false,
      "default": "model",
      "description": "Group report by: model, day, week"
    },
    "monthly": {
      "type": "number",
      "required": false,
      "description": "Monthly budget amount (budget set)"
    },
    "at": {
      "type": "string",
      "required": false,
      "description": "Alert threshold percentage (budget alert)"
    }
  },
  "output_schema": {
    "format": "json",
    "fields": [
      "token_count",
      "cost",
      "model",
      "usage_by_period",
      "budget_status"
    ]
  },
  "examples": [
    {
      "intent": "計算文件的 Token 數",
      "invocation": "token-meter count -f document.md --model gpt-4o"
    },
    {
      "intent": "查看本月費用報表",
      "invocation": "token-meter report --month 2026-04 --group-by model"
    }
  ],
  "error_codes": {
    "1": "File not found",
    "2": "Unsupported model"
  },
  "tags": [
    "token",
    "cost",
    "budget",
    "llm",
    "tracking"
  ],
  "status": "available",
  "source": "https://github.com/clibrary-hub/cli-tools/tree/main/manifests/B28-token-meter"
}