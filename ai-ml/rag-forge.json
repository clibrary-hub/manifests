{
  "name": "rag-forge",
  "version": "1.0.0",
  "category": "ai-ml",
  "description": "Auto-build a RAG pipeline: parse documents, chunk text, build a vector index, and serve an HTTP API for semantic search QA.",
  "intent_triggers": [
    "幫我建一個 RAG 知識庫",
    "把這個資料夾的文件做成向量索引",
    "我要啟動一個可以語義搜尋的 API",
    "如何對這些文件做 chunk 和 embedding",
    "幫我查一下這份文件裡有沒有相關內容",
    "build a RAG index from my docs",
    "launch a semantic search API",
    "create vector embeddings for these files",
    "query my document knowledge base",
    "幫我把 PDF 和 Word 文件建成可搜尋的知識庫"
  ],
  "input_schema": {
    "command": {
      "type": "enum",
      "required": true,
      "description": "Subcommand: build, serve, query"
    },
    "source": {
      "type": "string",
      "required": false,
      "description": "Source directory for document indexing (build)"
    },
    "output": {
      "type": "string",
      "required": false,
      "description": "Output directory for index (build)"
    },
    "model": {
      "type": "string",
      "required": false,
      "default": "paraphrase-multilingual-MiniLM-L12-v2",
      "description": "Sentence-transformers embedding model name"
    },
    "index": {
      "type": "string",
      "required": false,
      "description": "Path to index.json (serve/query)"
    },
    "host": {
      "type": "string",
      "required": false,
      "default": "0.0.0.0",
      "description": "API server host (serve)"
    },
    "port": {
      "type": "integer",
      "required": false,
      "default": 8000,
      "description": "API server port (serve)"
    },
    "question": {
      "type": "string",
      "required": false,
      "description": "Query question (query)"
    },
    "top_k": {
      "type": "integer",
      "required": false,
      "default": 3,
      "description": "Number of top results to return"
    }
  },
  "output_schema": {
    "format": "json",
    "fields": [
      "answer",
      "sources",
      "context",
      "index_path",
      "chunk_count"
    ]
  },
  "examples": [
    {
      "intent": "把 docs 資料夾建成 RAG 索引",
      "invocation": "rag-forge build ./docs --output ./index"
    },
    {
      "intent": "啟動 API 並查詢知識庫",
      "invocation": "rag-forge serve --index ./index/index.json --port 8000"
    },
    {
      "intent": "Query the local index for an answer",
      "invocation": "rag-forge query --index ./index/index.json \"What is the project architecture?\" --top-k 5"
    }
  ],
  "error_codes": {
    "1": "Source directory not found",
    "2": "Index file not found",
    "3": "Required dependency not installed (fastapi/uvicorn/pymupdf/docx)"
  },
  "tags": [
    "rag",
    "embedding",
    "vector-search",
    "semantic-search",
    "fastapi",
    "documents"
  ],
  "status": "spec"
}