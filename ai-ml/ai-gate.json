{
  "name": "ai-gate",
  "version": "1.0.0",
  "category": "ai-ml",
  "description": "CI/CD quality gate that checks AI-generated code against complexity, security, style, and coverage rules.",
  "intent_triggers": [
    "檢查這次 PR 的程式碼品質",
    "跑 AI 品質關卡",
    "設定品質檢查的閾值",
    "輸出 JUnit XML 給 CI 用",
    "只檢查複雜度和安全項目",
    "run the AI quality gate",
    "check code quality for this PR",
    "output JUnit XML for CI pipeline",
    "configure quality thresholds in YAML",
    "幫我檢查 main..feature 的變更有沒有問題"
  ],
  "input_schema": {
    "action": {
      "type": "enum",
      "required": true,
      "description": "Action: check",
      "default": "check"
    },
    "ref": {
      "type": "string",
      "required": false,
      "description": "Git reference range to check (e.g., main..feature)",
      "default": null
    },
    "config": {
      "type": "string",
      "required": false,
      "description": "Path to .ai-gate.yaml configuration file",
      "default": ".ai-gate.yaml"
    },
    "only": {
      "type": "string",
      "required": false,
      "description": "Comma-separated checks to run only",
      "default": null
    },
    "skip": {
      "type": "string",
      "required": false,
      "description": "Comma-separated checks to skip",
      "default": null
    },
    "output": {
      "type": "string",
      "required": false,
      "description": "Output report file path",
      "default": null
    },
    "fail_on": {
      "type": "enum",
      "required": false,
      "description": "Fail threshold: warning or error",
      "default": "error"
    }
  },
  "output_schema": {
    "format": "text",
    "fields": [
      "changed_files",
      "errors",
      "warnings",
      "checks_passed",
      "result"
    ]
  },
  "examples": [
    {
      "intent": "檢查 PR 中的所有變更",
      "invocation": "ai-gate check"
    },
    {
      "intent": "僅執行複雜度和安全檢查",
      "invocation": "ai-gate check --only complexity,security"
    },
    {
      "intent": "Output JUnit XML for CI",
      "invocation": "ai-gate check -o junit.xml"
    }
  ],
  "error_codes": {
    "1": "Quality gate failed",
    "2": "Invalid configuration file"
  },
  "tags": [
    "ci-cd",
    "quality-gate",
    "code-quality",
    "security",
    "ai-ml"
  ],
  "status": "available",
  "source": "https://github.com/clibrary-hub/cli-tools/tree/main/manifests/D67-ai-gate"
}