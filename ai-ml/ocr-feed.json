{
  "name": "ocr-feed",
  "version": "1.0.0",
  "category": "ai-ml",
  "description": "Extract text from images via OCR and convert to agent-readable markdown format.",
  "intent_triggers": [
    "從截圖中提取文字",
    "對圖片執行 OCR 辨識",
    "幫我把白板照片轉成文字",
    "批次處理截圖目錄中的文字",
    "從剪貼簿圖片擷取文字",
    "extract text from screenshots",
    "run OCR on image files",
    "convert handwritten notes to text",
    "batch OCR a folder of images",
    "幫我 OCR 這張 code screenshot 並保留縮排"
  ],
  "input_schema": {
    "command": {
      "type": "enum",
      "required": true,
      "description": "Subcommand: extract, batch",
      "default": "extract"
    },
    "image": {
      "type": "string",
      "required": false,
      "description": "Input image file path"
    },
    "lang": {
      "type": "string",
      "required": false,
      "default": "chi_tra+eng",
      "description": "OCR language(s), e.g., chi_tra+eng, eng"
    },
    "output": {
      "type": "string",
      "required": false,
      "description": "Output file path for extracted text"
    },
    "clipboard": {
      "type": "boolean",
      "required": false,
      "default": false,
      "description": "Read image from clipboard instead of file"
    },
    "preprocess": {
      "type": "boolean",
      "required": false,
      "default": false,
      "description": "Auto preprocess: enhance contrast, denoise, binarize"
    },
    "dpi": {
      "type": "integer",
      "required": false,
      "description": "DPI for OCR processing"
    },
    "crop": {
      "type": "string",
      "required": false,
      "description": "Crop region: 'x,y,width,height'"
    },
    "mode": {
      "type": "enum",
      "required": false,
      "description": "Special mode: code, table, handwriting"
    },
    "merge": {
      "type": "boolean",
      "required": false,
      "default": false,
      "description": "Merge batch results into a single file"
    }
  },
  "output_schema": {
    "format": "text",
    "fields": ["extracted_text", "confidence", "language", "output_file"]
  },
  "examples": [
    {
      "intent": "從截圖中提取繁體中文與英文文字",
      "invocation": "ocr-feed extract screenshot.png --lang chi_tra+eng"
    },
    {
      "intent": "批次處理截圖目錄並合併為單一 Markdown 檔案",
      "invocation": "ocr-feed batch ./screenshots/ -o combined.md --merge"
    }
  ],
  "error_codes": {
    "1": "Image file not found",
    "2": "Tesseract OCR not installed"
  },
  "tags": ["ocr", "image", "text-extraction", "tesseract"]
}
